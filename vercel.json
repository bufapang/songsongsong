{
  "version": 2,
  "buildCommand": "mkdir -p public && cp index.html public/ && cp -r songs public/ 2>/dev/null || true",
  "devCommand": "python3 -m http.server 3000",
  "functions": {
    "api/*.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "env": {
    "REPLICATE_API_TOKEN": "@replicate-api-token"
  }
}
