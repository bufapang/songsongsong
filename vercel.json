{
  "version": 2,
  "buildCommand": "mkdir -p public && cp index.html public/",
  "devCommand": "python3 -m http.server 3000",
  "functions": {
    "api/generate.js": {
      "runtime": "@vercel/node@20.x"
    }
  },
  "routes": [
    {
      "src": "/api/generate",
      "dest": "/api/generate.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
